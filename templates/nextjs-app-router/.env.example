# Next.js + Supabase env contract. Commit .env.example, never .env.local.
# Every key here must be present (value may be empty) for the app to boot.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never prefix with NEXT_PUBLIC_. Never read from "use client".
SUPABASE_SERVICE_ROLE_KEY=

# Playwright base URL override (rare).
# PLAYWRIGHT_BASE_URL=http://localhost:3000
