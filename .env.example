# Soup — environment contract
# Copy to .env and fill in. session_start hook loads this.
#
# ─── REQUIRED vs OPTIONAL (F7 clarity) ───────────────────────
# REQUIRED before any `just go` / `just plan` run:
#   - ANTHROPIC_API_KEY   (meta-prompter + every subagent)
#
# REQUIRED-FOR-RAG (any `just rag` / `python -m rag.ingest|search`):
#   - OPENAI_API_KEY      LightRAG's default embedding func is
#                         ``openai_embed`` (1536-dim). Missing key →
#                         cryptic "api key not set" from the openai SDK
#                         on first embed call. If you must avoid OpenAI,
#                         override ``LightRagClient.embedding_func`` — but
#                         the default path needs this.
#
# OPTIONAL (stub-safe: soup starts fine with empty values; only
# features that touch the corresponding integration break):
#   - POSTGRES_*          needed once RAG ingestion or apps touch Postgres
#                         (agents: sql-specialist, rag-researcher,
#                         docs-ingester, python-dev when reading RAG)
#   - GITHUB_TOKEN        needed by github-agent and /pr-create flows
#   - ADO_PAT             needed by ado-agent, ingesting ADO wiki via RAG
#   - GITHUB_ORG          optional; defaults to `streck`
#   - ADO_ORG, ADO_PROJECT  optional; set when using the ado-agent
#
# Framework-config values (SOUP_*) have safe defaults — override
# only when tuning.
#
# Sign-off: if a key is empty, the subagent whose TaskStep.env lists
# it will receive an absent var (never the parent env's value by
# default). See orchestrator/agent_factory.py _filter_parent_env.

# ─── Anthropic / Claude ──────────────────────────────────────
# REQUIRED.
ANTHROPIC_API_KEY=
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_OPUS=claude-opus-4-6
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001

# ─── OpenAI (embeddings — REQUIRED if using RAG with default LightRAG embed) ───
# LightRAG uses openai_embed by default. Set OPENAI_API_KEY to enable
# RAG ingest/search. If you want to swap embedders, override
# LightRagClient.embedding_func.
OPENAI_API_KEY=

# ─── Postgres (RAG + app data) ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=soup_rag
POSTGRES_USER=soup
POSTGRES_PASSWORD=

# ─── GitHub (stub — set on work laptop) ─────────────────────
GITHUB_TOKEN=
GITHUB_ORG=streck

# ─── Azure DevOps (stub — set on work laptop) ───────────────
ADO_ORG=
ADO_PROJECT=
ADO_PAT=

# ─── Framework config ────────────────────────────────────────
SOUP_LOG_LEVEL=info
SOUP_BUDGET_SEC_DEFAULT=3600
SOUP_WORKTREE_BASE=.soup/worktrees
